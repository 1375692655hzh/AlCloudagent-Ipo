# Skill C (hkex-pdf-field-extractor) 配置示例
# 把本文件复制为 .env（仓库根目录）或导出到 shell。
#
# 任何 OpenAI-compatible 服务都行：GLM、MiniMax、OpenAI、Azure OpenAI、
# Claude（通过兼容层）、本地 vLLM 等。
#
# 默认推荐 GLM-5.2 或 MiniMax-M3（国内访问快，免费额度大）。

# LLM 模型名（必填）
LLM_MODEL=glm-5.2

# API base URL（GLM/MiniMax 等需指定，OpenAI 官方可留空）
# 示例（占位，实际值需查阅对应服务的 API 文档）：
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=

# API key（必填）
LLM_API_KEY=sk-your-key-here
